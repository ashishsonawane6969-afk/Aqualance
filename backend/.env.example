# ── Database ────────────────────────────────
DATABASE_URL=mysql://user:pass@host:3306/aqualance

# ── Auth ────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-very-long-random-secret

# ── MFA (TOTP) ───────────────────────────────
# REQUIRED in production. Must be INDEPENDENT of JWT_SECRET.
# If either leaks, the other must not compromise the second-factor.
#
# MFA_ENCRYPTION_KEY: encrypts TOTP secrets at rest (AES-256-GCM)
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_KEY

# MFA_TEMP_SECRET: signs short-lived MFA pending tokens (5 min TTL)
#   Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   MUST differ from JWT_SECRET — validated at startup
MFA_TEMP_SECRET=GENERATE_INDEPENDENTLY_FROM_JWT_SECRET

# ── GitHub SQL Auto-Export ──────────────────
# Get a token at: https://github.com/settings/tokens
# Scopes needed: repo (Contents: Read & Write)
# SECURITY: The exported dump EXCLUDES users/token_revocations/otp_pending tables.
# Use a dedicated PRIVATE repository — never export to a public repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=Aqualance
# Optional — defaults to database/aqualence_complete.sql
# GITHUB_SQL_PATH=database/aqualence_complete.sql

# ── Optional ────────────────────────────────
BCRYPT_ROUNDS=12
ALERT_WEBHOOK_URL=https://hooks.slack.com/...
