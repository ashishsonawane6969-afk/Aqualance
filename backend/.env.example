# ── Database ────────────────────────────────
DATABASE_URL=mysql://user:pass@host:3306/aqualance

# ── Auth ────────────────────────────────────
JWT_SECRET=your-very-long-random-secret

# ── GitHub SQL Auto-Export ──────────────────
# Get a token at: https://github.com/settings/tokens
# Scopes needed: repo (Contents: Read & Write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=Aqualance
# Optional — defaults to database/aqualence_complete.sql
# GITHUB_SQL_PATH=database/aqualence_complete.sql

# ── Optional ────────────────────────────────
BCRYPT_ROUNDS=12
ALERT_WEBHOOK_URL=https://hooks.slack.com/...
